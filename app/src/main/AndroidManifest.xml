<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:name=".app.DiMentoApplication"
        android:allowBackup="true"
        android:icon="@drawable/ic_dimento_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_dimento_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.DiMento">

        <activity
            android:name=".app.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.DiMento">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".core.notifications.NotificationActionReceiver"
            android:exported="false" />
    </application>

</manifest>
